# ============================================
# 短剧漫剧创作工坊 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填写配置
# ============================================

# ==================== 数据库配置 ====================
# 数据库类型：postgresql 或 mysql
DATABASE_TYPE=postgresql

# ===== PostgreSQL (Supabase) 配置 =====
# 方式1: 使用 DATABASE_URL 连接字符串
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# 方式2: 使用 Supabase 云服务（推荐）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== 本地 PostgreSQL 直连配置 =====
# 用于绕过 Supabase PostgREST schema cache 问题
# PGDATABASE_URL=postgresql://user:password@localhost:5432/drama_studio
# PGDATABASE_IPV4_HOST=127.0.0.1

# ==================== 对象存储配置 ====================

# === 阿里云 OSS（推荐国内用户）===
S3_ENDPOINT=https://your-bucket.oss-cn-chengdu.aliyuncs.com
S3_PUBLIC_ENDPOINT=https://your-bucket.oss-cn-chengdu.aliyuncs.com
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-access-key-secret
S3_BUCKET=your-bucket-name
S3_REGION=oss-cn-chengdu

# === AWS S3 ===
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_PUBLIC_ENDPOINT=https://your-bucket.s3.amazonaws.com
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1

# === 本地 MinIO ===
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=drama-studio
# S3_REGION=us-east-1

# ==================== LLM API 配置 ====================
# 豆包/火山引擎 API
# 获取地址: https://console.volcengine.com/ark
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 图像生成 API 配置 ====================
IMAGE_API_KEY=your-image-api-key
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 视频生成 API 配置 ====================
VIDEO_API_KEY=your-video-api-key
VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 语音合成 API 配置 ====================
VOICE_API_KEY=your-voice-api-key
VOICE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== Coze API 配置（可选） ====================
# 如果你使用 Coze 平台的 Bot
# COZE_API_KEY=your-coze-api-key
# COZE_BASE_URL=https://api.coze.com
# COZE_BOT_ID=your-bot-id
