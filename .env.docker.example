# 短剧漫剧创作工坊 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# 数据库类型：postgresql 或 mysql
# 注意：当前版本仅支持 PostgreSQL (Supabase)，MySQL 支持正在开发中
DATABASE_TYPE=postgresql

# ===== PostgreSQL (Supabase) 配置 =====
# 方式1: 使用 DATABASE_URL 连接字符串
DATABASE_URL=postgresql://postgres:postgres@db:5432/drama_studio

# 方式2: 使用 Supabase 云服务（推荐）
# 注册地址: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# ===== MySQL 配置（本地开发） =====
# 如果使用 MySQL，请取消注释以下配置
# DATABASE_TYPE=mysql
# DATABASE_URL=mysql://root:password@localhost:3306/drama_studio

# ==================== 对象存储配置 ====================
# MinIO 本地存储配置
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=drama-studio
S3_REGION=us-east-1

# 如果使用云存储（如阿里云 OSS、AWS S3），请修改为对应的配置
# S3_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=oss-cn-beijing

# ==================== LLM API 配置 ====================
# 豆包/字节跳动大模型 API
# 获取地址: https://console.volcengine.com/ark
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2-0-pro

# ==================== 图像生成 API 配置 ====================
IMAGE_API_KEY=your-image-api-key
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 视频生成 API 配置 ====================
VIDEO_API_KEY=your-video-api-key
VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 语音合成 API 配置 ====================
VOICE_API_KEY=your-voice-api-key
VOICE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ==================== 其他配置 ====================
NODE_ENV=production
PORT=5000
